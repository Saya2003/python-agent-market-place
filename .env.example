APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

GEMINI_API_KEY=replace_with_google_ai_studio_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_NEGOTIATION=gemini-2.0-flash
GEMINI_ENABLE_GROUNDING=false

CIRCLE_API_KEY=replace_with_circle_key
CIRCLE_ENTITY_SECRET=replace_with_circle_entity_secret
CIRCLE_API_BASE=https://api.circle.com
SETTLEMENT_MODE=stub
CIRCLE_ENTITY_SECRET_RAW_HEX=replace_with_raw_64_hex_if_using_live_circle
CIRCLE_COORDINATOR_WALLET_UUID=replace_with_circle_wallet_uuid
CIRCLE_RESEARCH_WALLET_ADDRESS=0xreplace_with_research_address
CIRCLE_WRITER_WALLET_ADDRESS=0xreplace_with_writer_address
CIRCLE_BLOCKCHAIN=ARC-TESTNET
CIRCLE_USDC_TOKEN_ID=
CIRCLE_USDC_TOKEN_ADDRESS=0xreplace_with_usdc_token_address_if_no_token_id

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=replace_with_supabase_anon_or_service_role_key
SUPABASE_TABLE=agent_transactions
SUPABASE_AGENTS_TABLE=marketplace_agents

COORDINATOR_WALLET_ID=wallet_coordinator
RESEARCH_WALLET_ID=wallet_research
WRITER_WALLET_ID=wallet_writer

LOG_PATH=logs/transactions.jsonl
ETH_MAINNET_ESTIMATED_TX_COST=0.75
ARC_EXPLORER_TX_URL_TEMPLATE=https://arcscan.example/tx/{tx_hash}

POLICY_MAX_PAYMENT_USDC=0.01
POLICY_DAILY_CAP_USDC=50
POLICY_WALLET_ALLOWLIST=wallet_coordinator,wallet_research,wallet_writer
POLICY_APPROVAL_THRESHOLD_USDC=0.002
